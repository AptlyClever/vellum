<?xml version="1.0" encoding="UTF-8"?>
<!--
  WinSW service definition for Vellum UE Agent.
  install.ps1 stamps absolute paths into VellumUeAgent.xml next to the exe.
-->
<service>
  <id>VellumUeAgent</id>
  <name>Vellum UE Agent</name>
  <description>Polls Vellum for ue_capture jobs and talks to the warm Lookdev Worker on loopback. Do not babysit a PowerShell window.</description>
  <executable>{{PWSH}}</executable>
  <arguments>-NoProfile -ExecutionPolicy Bypass -File "{{AGENT_PS1}}" -VellumBase "{{VELLUM_BASE}}" -HostName "{{HOST_NAME}}"</arguments>
  <workingdirectory>{{REPO_ROOT}}</workingdirectory>
  <logpath>{{LOG_DIR}}</logpath>
  <log mode="roll-by-size">
    <sizeThreshold>10485760</sizeThreshold>
    <keepFiles>8</keepFiles>
  </log>
  <onfailure action="restart" delay="10 sec"/>
  <onfailure action="restart" delay="30 sec"/>
  <onfailure action="restart" delay="60 sec"/>
  <resetfailure>1 hour</resetfailure>
  <startmode>Automatic</startmode>
  <delayedAutoStart>true</delayedAutoStart>
  <stoptimeout>20 sec</stoptimeout>
  <env name="VELLUM_UE_HOST" value="{{HOST_NAME}}"/>
</service>
