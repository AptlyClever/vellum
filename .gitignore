# Vellum — gitignore

# Secrets / env
.env
.env.local
*.pem
*.key

# OS / editor
.DS_Store
.idea/
.vscode/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# Runtime register (seeded from config/humble-seed.yaml)
data/asset-register.yaml
data/intake-runs.yaml
data/jobs.sqlite3
data/derived-outputs.yaml
data/*.sqlite3

# Never track vault raw assets (vault lives outside this repo)

# Runtime (WinSW binary, stamped XML, service logs) — machine-local
tools/unreal/host-install/runtime/

